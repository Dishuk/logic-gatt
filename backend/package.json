{
  "name": "logic-gatt-backend",
  "version": "1.0.0",
  "description": "Backend server for logic-gatt plugin system",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "node scripts/install-plugin-deps.js",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@logic-gatt/shared": "file:../shared",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^2.0.0",
    "cross-env": "^7.0.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^2.0.0"
  }
}
